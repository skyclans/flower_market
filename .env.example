# 꽃장부 환경변수 — 복사해서 .env 로 쓰고 값 채우기 (.env 는 커밋 금지)

# ── DB (Phase 1 적재/API 공통) ─────────────────────────────
DATABASE_URL=postgresql://flower:flower@localhost:5432/flower

# ── 배치 소스 선택 ─────────────────────────────────────────
# excel  = flower.at.or.kr 엑셀 (Phase 0 검증 완료, 화훼 지원, 기본값)
# openapi= data.go.kr 15141808 (운영 후보, serviceKey 필요, 화훼 포함여부 확인 필요)
SOURCE=excel

# 수집 대상 (쉼표구분 시장코드, 또는 all). 기본: 양재
MARKETS=0000000001
LAST_N=1

# ── Open API (SOURCE=openapi 일 때만) ──────────────────────
# data.go.kr 활용신청 후 발급되는 일반 인증키(Decoding)
DATA_GO_KR_SERVICE_KEY=
# 활용신청 상세의 정확한 엔드포인트 URL 로 교체
OPENAPI_ENDPOINT=
# 프로젝트 표준코드 → 이 API 의 whsl_mrkt_code 매핑(JSON). 15141818 로 조회.
# 예: {"0000000001":"110001"}
OPENAPI_MARKET_CODES={}
